# ─────────────────────────────────────────────────────────────────────────────
# Assay environment. Copy to `.env.local` and fill in.
# NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (required) ─────────────────────────────────────────────────────
# From your Supabase project: Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — server-only, bypasses RLS (background jobs only).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
#
# After setting these, run the migrations in supabase/migrations/ (in order)
# in the Supabase SQL editor to create the scans / scan_findings /
# ownership_proofs / scan_usage / monitored_apps / email_log tables (with RLS).

# ── Anthropic (required for plain-language fixes) ───────────────────────────
# Without it, scans still complete using raw finding text; the /sample demo
# report renders with no keys at all.
ANTHROPIC_API_KEY=sk-ant-...

# ── Inngest (optional in dev, required in prod) ─────────────────────────────
# In dev the Inngest dev server runs keyless (npx inngest-cli@latest dev).
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ── Resend (email alerts — optional) ────────────────────────────────────────
# Powers the regression alert ("a change opened a security hole") and the
# weekly watch digest. Without it, scans + monitoring still work; the app just
# never emails. Create a key at https://resend.com and verify your sender.
RESEND_API_KEY=
EMAIL_FROM="Assay <alerts@assay.dev>"
# Absolute base URL used for links inside emails (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://assay-jet.vercel.app

# ── GitHub sign-in (OAuth) ──────────────────────────────────────────────────
# Auth is Supabase Auth → GitHub, used ONLY to sign users into Assay (no repo
# access). Create a classic OAuth App at https://github.com/settings/developers
# and put its client id/secret into the Supabase GitHub provider
# (Authentication → Providers) — not read from this file, just recorded here
# for reference. Add <your-site>/auth/callback as the redirect URL.
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
